# ─────────────────────────────────────────────────────────────
#  TaskFlow — Variáveis de Ambiente
#  Copie este arquivo para .env e preencha os valores reais.
# ─────────────────────────────────────────────────────────────

# ── Banco de dados ──────────────────────────────────────────
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:sua_senha@localhost:5432/taskflow"

# ── Servidor ────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── JWT ─────────────────────────────────────────────────────
# Gere um secret forte: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="troque_por_um_secret_forte_de_pelo_menos_64_chars"
JWT_EXPIRES_IN="7d"

# ── CORS ────────────────────────────────────────────────────
# Em produção, coloque a URL real do seu frontend
CORS_ORIGIN="http://localhost:5500"

# ── Rate Limit ──────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000   # 15 minutos em ms
RATE_LIMIT_MAX=100            # máx de requisições por janela
AUTH_RATE_LIMIT_MAX=10        # máx de tentativas de login por janela

# ── Supabase (opcional) ─────────────────────────────────────
# Use estas variáveis apenas se quiser conectar a um projeto Supabase.
SUPABASE_URL="https://<seu-projeto>.supabase.co"
SUPABASE_SECRET_KEY="sua_chave_secreta_service_role"

